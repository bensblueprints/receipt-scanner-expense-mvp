{
  "name": "snapreceipt",
  "version": "1.0.0",
  "description": "Local receipt scanner + expense logger. OCR runs 100% on your machine, prefills a review form — you decide what gets saved. Pay once, own it forever.",
  "author": "Ben (bensblueprints)",
  "license": "MIT",
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start": "electron .",
    "postinstall": "node scripts/setup-native.js && node scripts/fetch-ocr-data.js",
    "test": "node test/smoke.js",
    "dist": "electron-builder --win nsis"
  },
  "dependencies": {
    "better-sqlite3": "^12.2.0",
    "date-fns": "^4.4.0",
    "pdf-lib": "^1.17.1",
    "tesseract.js": "7.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "@vitejs/plugin-react": "^4.4.0",
    "electron": "^33.4.0",
    "electron-builder": "^25.1.8",
    "framer-motion": "^11.18.2",
    "lucide-react": "^0.474.0",
    "pureimage": "^0.4.18",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^4.1.0",
    "tesseract.js-core": "7.0.0",
    "vite": "^6.3.5"
  },
  "build": {
    "appId": "com.bensblueprints.snapreceipt",
    "productName": "Snapreceipt",
    "files": [
      "main.js",
      "preload.js",
      "src/**",
      "dist/**",
      "vendor/**",
      "ocr-assets/**",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "menuCategory": "OneTimeSuite"
    },
    "directories": {
      "output": "release"
    },
    "asarUnpack": [
      "vendor/**",
      "ocr-assets/**",
      "node_modules/better-sqlite3/**",
      "node_modules/tesseract.js/**",
      "node_modules/tesseract.js-core/**"
    ]
  }
}
